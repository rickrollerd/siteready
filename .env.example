# SiteReady Environment Variables

# Anthropic API Key (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port (Railway will set this automatically, defaults to 3000 locally)
PORT=3000

# Optional: Stripe keys (add after Stripe account setup)
# STRIPE_SECRET_KEY=sk_live_your_key_here
# STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# SiteReady Environment Variables
# Copy this file to .env and fill in your actual values

# DeepSeek API Key (get from https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Server Port
PORT=3849

# Environment (development/production)
NODE_ENV=development

# Optional: Internal API key for additional security
# API_KEY=generate_a_secure_random_key_here

# Optional: CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3849,https://siteready.nz

# Optional: Rate limiting settings
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
# RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window per IP

# Optional: Stripe keys (for future payments)
# STRIPE_SECRET_KEY=sk_live_your_key_here
# STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here